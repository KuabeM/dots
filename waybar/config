{
    // "layer": "top", // Waybar at top layer
    // "position": "bottom", // Waybar position (top|bottom|left|right)
    "height": 20, // Waybar height (to be removed for auto height)
    // "width": 1280, // Waybar width
    // Choose the order of the modules
    "modules-left": ["sway/workspaces", "sway/mode", "sway/scratchpad", "custom/media"],
    "modules-center": ["sway/window"],
    //"modules-right": ["mpd", "idle_inhibitor", "pulseaudio", "network", "cpu", "memory", "temperature", "backlight", "battery", "battery#bat2", "clock"],
    "modules-right": ["network", "pulseaudio", "cpu", "memory", "backlight", "battery", "clock", "idle_inhibitor", "tray"],
    // Modules configuration
    "sway/workspaces": {
      "disable-scroll": true,
      "all-outputs": true
    //  "format": "{name} {icon}",
    //  "format-icons": {
    //  "1": "яДа",
    //  "2": "яЙи",
    //  "3": "яДб",
    //         "4": "яЖ╝",
    //         "5": "яБ╡",
    //         "urgent": "яБк",
    //    "focused": "яЖТ",
    //    "default": "яДС"
    //  }
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/window": {
        "max-length": 45,
        "tooltip": false
    },
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", "яЛТ"],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "яБо",
            "deactivated": "яБ░"
        }
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    "clock": {
        // "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%H:%M:%S - %d-%m-%Y}",
        "format-alt": "{:%Y-%m-%d}"
    },
    "cpu": {
        "format": "{usage:2}% яЛЫ",
        "tooltip": true,
        "interval": 2,
        "format-alt": "Load: {load}"
    },
    "memory": {
        "format": "{:2}% яГЙ"
    },
    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}┬░C {icon}",
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": ["яЛЙ", "яЭй"]
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-icons": ["яЖЕ", "яДС"]
    },
    "battery": {
        // "bat": "BAT0",
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% яЧз",
        "format-plugged": "{capacity}% яЗж",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "max-length": 30,
        "interval": 1,
        "format-wifi": "яЗл  ({signalStrength}%) {essid}",
        "format-ethernet": "яГБ  {ipaddr}/{cidr}",
        "format-linked": "{ifname} (No IP)",
        "format-disconnected": "тЬХ Disconnected",
        "format": "ЁЯФТ {ifname}",
        "format-alt": "Down: {bandwidthDownBits}, Up: {bandwidthUpBits}",
        "tooltip-format": "{ifname} | Down: {bandwidthDownBits}, Up: {bandwidthUpBits}"
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon} яКФ {format_source}",
        "format-bluetooth-muted": "тЬХ {icon} яКФ {format_source}",
        "format-muted": "тЬХ {format_source}",
        "format-source": " | {volume}% яД░",
        "format-source-muted": " | яД▒",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яАе",
            "headset": "яАе",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАж", "яАз", "яАи"]
        },
        "on-click": "pavucontrol"
    },
    "custom/media": {
        "format": "{icon} {}",
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            "spotify": "яЖ╝",
            "default": "ЁЯОЬ"
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
        //"exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
    },
    "wireplumber": {
        "format": "{volume}% {icon}",
        "format-muted": "яАж",
        "on-click": "pavucontrol",
        "format-icons": ["яАж", "яАз", "яАи"]
    }
}
